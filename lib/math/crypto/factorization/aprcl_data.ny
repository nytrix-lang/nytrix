;; Keywords: factorization primality aprcl jacobi-sums
;; Integer-factorization routines for APRCL Jacobi-sum constants and proof data.
module std.math.crypto.factorization.aprcl_data(aprcl_q_prime_table, aprcl_jacobi_table_report, aprcl_jacobi_seed_full_report, aprcl_pair_congruence_report, aprcl_proof_report, verify_aprcl_proof_report)
use std.core
use std.math.nt
use std.os.clock (ticks)

mut _aprcl_sls_cache = nil
mut _aprcl_jpqs_cache = nil
mut _aprcl_aiq_cache = nil

fn _aprcl_sls_table(): list {
   if(!is_list(_aprcl_sls_cache)){ _aprcl_sls_cache = _aprcl_sls() }
   _aprcl_sls_cache
}

fn _aprcl_jpqs_table(): list {
   if(!is_list(_aprcl_jpqs_cache)){ _aprcl_jpqs_cache = _aprcl_jpqs() }
   _aprcl_jpqs_cache
}

fn _aprcl_aiQ_table(): list {
   if(!is_list(_aprcl_aiq_cache)){ _aprcl_aiq_cache = _aprcl_aiQ() }
   _aprcl_aiq_cache
}

fn aprcl_q_prime_table(): list {
   "Return the cached APRCL Q-prime schedule table."
   _aprcl_aiQ_table()
}

fn _aprcl_take(list: xs, int: start, int: count): list {
   def n = min(count, max(0, xs.len - start))
   mut out = list(n)
   __list_set_len(out, n)
   mut i = 0
   while(i < n){
      out[i] = xs[start + i]
      i += 1
   }
   out
}

fn _aprcl_z(any: x): bigint { is_bigint(x) ? x : Z(x) }

fn _aprcl_mod(any: x, any: n): bigint {
   def nz = _aprcl_z(n)
   mut r = _aprcl_z(x) % nz
   if(r < Z(0)){ r = r + nz }
   r
}

fn _aprcl_zero(int: n): list {
   mut out = list(n)
   __list_set_len(out, n)
   mut i = 0
   while(i < n){
      out[i] = Z(0)
      i += 1
   }
   out
}

fn _aprcl_coeffs(list: coeffs, int: PK, any: modulus): list {
   mut out = list(PK)
   __list_set_len(out, PK)
   mut i = 0
   while(i < PK){
      out[i] = i < coeffs.len ? _aprcl_mod(coeffs[i], modulus) : Z(0)
      i += 1
   }
   out
}

fn _aprcl_normalize(list: coeffs, int: PK, int: PL, int: PM, int: P, any: modulus): list {
   mut out = _aprcl_coeffs(coeffs, PK, modulus)
   mut I = PL
   while(I < PK){
      def t = out[I]
      if(t != Z(0)){
         mut J = 1
         while(J < P){
            def idx = I - J * PM
            out[idx] = out[idx] - t
            J += 1
         }
         out[I] = Z(0)
      }
      I += 1
   }
   I = 0
   while(I < PK){
      out[I] = _aprcl_mod(out[I], modulus)
      I += 1
   }
   out
}

fn _aprcl_mul(list: lhs, list: rhs, int: PK, int: PL, int: PM, int: P, any: modulus): list {
   def a = _aprcl_coeffs(lhs, PK, modulus)
   def b = _aprcl_coeffs(rhs, PK, modulus)
   mut tmp = _aprcl_zero(PK)
   mut I = 0
   while(I < PL){
      def ai = a[I]
      if(ai != Z(0)){
         mut J = 0
         while(J < PL){
            def bj = b[J]
            if(bj != Z(0)){
               def K = (I + J) % PK
               tmp[K] = tmp[K] + ai * bj
            }
            J += 1
         }
      }
      I += 1
   }
   _aprcl_normalize(tmp, PK, PL, PM, P, modulus)
}

fn _aprcl_square(list: coeffs, int: PK, int: PL, int: PM, int: P, any: modulus): list {
   def a = _aprcl_coeffs(coeffs, PK, modulus)
   mut tmp = _aprcl_zero(PK)
   mut I = 0
   while(I < PL){
      def ai = a[I]
      if(ai != Z(0)){
         mut K = (2 * I) % PK
         tmp[K] = tmp[K] + ai * ai
         def twice = ai + ai
         mut J = I + 1
         while(J < PL){
            def aj = a[J]
            if(aj != Z(0)){
               K = (I + J) % PK
               tmp[K] = tmp[K] + twice * aj
            }
            J += 1
         }
      }
      I += 1
   }
   _aprcl_normalize(tmp, PK, PL, PM, P, modulus)
}

fn _aprcl_pow(list: coeffs, any: exponent, int: PK, int: PL, int: PM, int: P, any: modulus): list {
   mut result = _aprcl_zero(PK)
   result[0] = Z(1)
   mut base = _aprcl_normalize(coeffs, PK, PL, PM, P, modulus)
   mut e = _aprcl_z(exponent)
   while(e > Z(0)){
      if(e % Z(2) == Z(1)){ result = _aprcl_mul(result, base, PK, PL, PM, P, modulus) }
      e = e / Z(2)
      if(e > Z(0)){ base = _aprcl_square(base, PK, PL, PM, P, modulus) }
   }
   result
}

fn _aprcl_inv_mod_int(int: x, int: m): int {
   mut u1, u3, v1, v3 = 1, x, 0, m
   while(v3 != 0){
      def q = u3 / v3
      def t1, t3 = u1 - v1 * q, u3 - v3 * q
      u1 = v1
      u3 = v3
      v1 = t1
      v3 = t3
   }
   (u1 + m) % m
}

fn _aprcl_seed_from_tables(list: sls, list: jpqs, int: mode, int: P, int: PL, int: Q): any {
   def myP = mode == 1 ? 1 : (mode == 2 ? 4 : P)
   mut i = 0
   while(i < jpqs.len){
      def row = jpqs[i]
      if(row == [0, 0, 0]){ return nil }
      if(int(row[0]) == Q && int(row[2]) == myP){
         def start = int(row[1])
         if(start + PL > sls.len){ return nil }
         return {"seed_index": i, "table_index": start, "coefficients": _aprcl_take(sls, start, PL)}
      }
      i += 1
   }
   nil
}

fn _aprcl_initial_plan(any: n): dict {
   def nz = _aprcl_z(n)
   def aiT, aiQ, aiNQ = _aprcl_aiT(), _aprcl_aiQ_table(), _aprcl_aiNQ()
   mut level, testing_qs = -1, 0
   mut S = Z(2)
   mut trace = []
   mut i = 0
   while(i < aiT.len && level < 0){
      S = Z(2)
      mut j = 0
      def limit = min(int(aiNQ.get(i)), aiQ.len)
      while(j < limit && level < 0){
         def Q = int(aiQ.get(j))
         def T = _aprcl_z(aiT.get(i))
         if(T % Z(Q - 1) == Z(0)){
            mut U = T * Z(Q)
            mut keep = true
            while(keep){
               U = U / Z(Q)
               S = S * Z(Q)
               keep = U % Z(Q) == Z(0)
            }
            if(S * S > nz){
               level = i
               testing_qs = j
            }
         }
         j += 1
      }
      trace = trace.append({"level": i, "S": S, "tested_qs": j})
      i += 1
   }
   {"found": level >= 0, "level": level, "testing_qs": testing_qs, "S": S, "trace": trace}
}

fn _aprcl_level_plan(any: n, int: level): dict {
   def nz = _aprcl_z(n)
   def aiT, aiQ, aiNQ = _aprcl_aiT(), _aprcl_aiQ_table(), _aprcl_aiNQ()
   mut S, j, found = Z(2), 0, false
   def T = _aprcl_z(aiT.get(level))
   def limit = min(int(aiNQ.get(level)), aiQ.len)
   while(j < limit && !found){
      def Q = int(aiQ.get(j))
      if(T % Z(Q - 1) == Z(0)){
         mut U = T * Z(Q)
         mut keep = true
         while(keep){
            U = U / Z(Q)
            S = S * Z(Q)
            keep = U % Z(Q) == Z(0)
         }
         if(S * S > nz){ found = true }
      }
      if(!found){ j += 1 }
   }
   {"found": found, "level": level, "testing_qs": j, "S": S}
}

