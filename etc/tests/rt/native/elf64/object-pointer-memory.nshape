shape elf64_object_pointer_memory {
  family "runtime-native"
  generator "native"
  features [native object elf64 pointer memory load64 store64]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-native-elf64-object-pointer-memory.o"
  expect compile_and_run
  source ny <<'NY'
use std.core

fn ptr_mem() i64 {
  def *int p = malloc(8)
  if p == nil { return 0 }
  store64_i(p, 41)
  def i64 v = load64_i(p)
  free(p)
  v + 1
}

ptr_mem()
NY
}