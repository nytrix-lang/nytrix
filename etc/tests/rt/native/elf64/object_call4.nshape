shape elf64_object_call4 {
  family "runtime-native"
  generator "native"
  features [native object elf64 call]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-native-elf64-object-call4.o"
  expect compile_and_run
  source ny <<'NY'
fn add4(i64 a, i64 b, i64 c, i64 d) i64 { a + b + c + d }
add4(1, 2, 3, 4)
NY
}
