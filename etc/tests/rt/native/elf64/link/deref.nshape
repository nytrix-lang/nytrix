shape x86_64_elf64_object_link_run_deref {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run pointer deref]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-link-run-deref.o"
  expect object_link_run_i64_42
  source ny <<'NY'
use std.core

fn ptr_deref() i64 {
  def *int p = malloc(8)
  if p == nil { return 0 }
  store64_i(p, 42)
  def i64 v = *p
  free(p)
  v
}

ptr_deref()
NY
}
