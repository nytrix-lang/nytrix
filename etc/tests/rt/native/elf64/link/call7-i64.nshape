shape x86_64_elf64_object_link_run_call7_i64 {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-link-run-call7-i64.o"
  expect object_link_run_i64_28
  source ny <<'NY'
fn add7(i64 a, i64 b, i64 c, i64 d, i64 e, i64 f, i64 g) i64 {
  a + b + c + d + e + f + g
}
add7(1, 2, 3, 4, 5, 6, 7)
NY
}
