shape x86_64_elf64_object_link_run_realloc_null_stub {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run pointer realloc]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-link-run-realloc-null-stub.o"
  expect object_link_run_i64_42
  source ny <<'NY'
use std.core

fn probe() i64 {
  def *int p = realloc(nil, 8)
  if p == nil { return 0 }
  store64_i(p, 42)
  def v = load64_i(p)
  free(p)
  v
}

probe()
NY
}
