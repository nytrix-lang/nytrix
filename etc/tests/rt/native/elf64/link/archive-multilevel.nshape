shape x86_64_elf64_link_archive_multilevel {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run archive multilevel]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-native-elf64-archive-multilevel-link.o"
  expect object_link_run_i64_82
  link "etc/tests/rt/native/elf64/link/ar_multi.a"
  source ny <<'NY'
extern "c" {
  fn ar_multi_a(i64 x) i64
}
def main = ar_multi_a(0)
NY
}
