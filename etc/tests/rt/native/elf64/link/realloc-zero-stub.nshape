shape x86_64_elf64_object_link_run_realloc_zero_stub {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run pointer realloc]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-link-run-realloc-zero-stub.o"
  expect object_link_run_i64_42
  source ny <<'NY'
use std.core

fn probe() i64 {
  def *int p = malloc(8)
  if p == nil { return 0 }
  def *int q = realloc(p, 0)
  if q == nil { 42 } else { 0 }
}

probe()
NY
}
