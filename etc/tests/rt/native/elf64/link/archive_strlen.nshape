shape x86_64_elf64_link_archive_strlen {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run archive strlen]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-native-elf64-archive-strlen-link.o"
  expect object_link_run_i64_53
  link "etc/tests/rt/native/elf64/link/ar_helper_strlen.a"
  source ny <<'NY'
extern "c" {
  fn ar_strlen_hello() i64
}
def main = ar_strlen_hello()
NY
}
