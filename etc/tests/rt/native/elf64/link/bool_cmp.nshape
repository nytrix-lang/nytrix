shape x86_64_elf64_object_link_run_bool_cmp {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run bool]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-link-run-bool-cmp.o"
  expect object_link_run_i64_1
  source ny <<'NY'
fn gt(i64 a, i64 b) bool {
  a > b
}
gt(5, 3)
NY
}
