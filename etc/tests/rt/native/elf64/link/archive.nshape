shape x86_64_elf64_link_archive {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run archive]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-native-elf64-archive-link.o"
  expect object_link_run_i64_84
  link "etc/tests/rt/native/elf64/link/ar_helper.a"
  source ny <<'NY'
extern "c" {
  fn ar_add42(i64 x) i64
}
def main = ar_add42(42)
NY
}
