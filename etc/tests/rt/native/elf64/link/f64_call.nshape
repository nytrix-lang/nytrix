shape x86_64_elf64_object_link_run_f64_call {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run f64 call]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-link-run-f64-call.o"
  expect object_link_run_f64_3.75
  source ny <<'NY'
fn add(f64 x, f64 y) f64 { x + y }
add(1.5, 2.25)
NY
}
