shape x86_64_elf64_native_runtime_print_int {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run runtime print]
  template ny-test-case
  flags "--native-only --no-progress --color=never"
  expect compile_and_run
  source ny <<'NY'
fn add(i64 a, i64 b) i64 {
  a + b
}
print(add(20, 22))
NY
}
