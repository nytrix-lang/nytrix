shape x86_64_elf64_object_link_run_i64 {
  family "runtime-native"
  generator "native"
  features [native object elf64 x86_64 nyir link-run]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-link-run-i64.o"
  expect object_link_run_i64_10
  source ny <<'NY'
fn add4(i64 a, i64 b, i64 c, i64 d) i64 {
  a + b + c + d
}
add4(1, 2, 3, 4)
NY
}
