shape elf64_object_f64_call {
  family "runtime-native"
  generator "native"
  features [native object elf64 f64 call]
  template ny-test-case
  flags "--native-backend x86_64 -emit-only -o /tmp/nytrix-native-elf64-object-f64-call.o"
  expect compile_and_run
  source ny <<'NY'
fn add(f64 x, f64 y) f64 { x + y }
add(1.5, 2.25)
NY
}