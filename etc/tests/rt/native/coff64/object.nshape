shape x86_64_coff_object_writer {
  family "runtime-native"
  generator "native"
  features ["native", "object", "coff", "x86_64", "nyir"]
  template ny-test-case
  flags "--native-backend x86_64 --host-triple x86_64-w64-windows-gnu -emit-only -o /tmp/nytrix-native-coff64-object-smoke.obj"
  expect compile_and_run
  source ny <<'NY'
def x = 42
x / 3 + x % 5
NY
}
