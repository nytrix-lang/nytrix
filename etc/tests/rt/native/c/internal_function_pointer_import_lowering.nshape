shape internal_function_pointer_import_lowering {
  family "runtime-native"
  generator "native"
  features [c-frontend ffi import-lowering function-pointer no-libclang]
  template ny-test-case
  flags "--c-frontend=nytrix -vv"
  expect compile_and_run
  source ny <<'NY'
#include "etc/tests/rt/ffi/internal_function_pointer_import.h" as "c"
use std.core

fn cmp(ptr a, ptr b) i32 {
  def i64 av = load64_i(a)
  def i64 bv = load64_i(b)
  if av < bv { return -1 }
  if av > bv { return 1 }
  0
}

fn probe() i64 {
  def *int p = malloc(16)
  if p == nil { return 0 }
  store64_i(p, 20)
  store64_i(p, 10, 8)
  c.qsort(p, 2, 8, cmp)
  def i64 first = load64_i(p)
  def i64 second = load64_i(p, 8)
  free(p)
  first * 100 + second
}

assert(probe() == 1020, "internal c function pointer import qsort callback")
1 + 2
NY
}
