shape layout_unsupported_diagnostic {
  family "runtime-native"
  generator "native"
  features ["c-frontend", "negative", "diagnostic"]
  template ny-test-case
  flags "--c-frontend=nytrix -vv"
  expect compile_fail
  source ny <<'NY'
#include "etc/tests/rt/native/fixtures/unsupported-flexible-mid.h"
1 + 2
NY
}
