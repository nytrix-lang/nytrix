shape zero_array_extent_diagnostic {
  family "runtime-native"
  generator "native"
  features ["c-frontend", "negative", "diagnostic", "array"]
  template ny-test-case
  flags "--c-frontend=nytrix -vv"
  expect compile_fail
  source ny <<'NY'
#include "etc/tests/rt/native/fixtures/unsupported_zero_array_extent.h"
1 + 2
NY
}
