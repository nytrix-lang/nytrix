shape macro_array_layout {
  family "runtime-native"
  generator "native"
  features ["c-frontend", "ffi", "preprocessor", "define", "array", "layout"]
  template ny-test-case
  flags "--c-frontend=nytrix -vv"
  expect compile_and_run
  source ny <<'NY'
#include "etc/tests/rt/ffi/internal_aggregate.h"
1 + 2
NY
}
