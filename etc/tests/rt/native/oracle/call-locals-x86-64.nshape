shape oracle_call_locals_x86_64 {
  family "runtime-native"
  generator "native"
  features [native x86_64 oracle result call locals]
  template ny-test-case
  flags "--native-result-oracle=40"
  expect compile_and_run
  source ny <<'NY'
fn add4(i64 a, i64 b, i64 c, i64 d) i64 {
  a + b + c + d
}
mut x = 10
mut y = 20
add4(1, 2, 3, 4) + x + y
NY
}
