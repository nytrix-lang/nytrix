shape oracle_bool_arg_x86_64 {
  family "runtime-native"
  generator "native"
  features [native x86_64 oracle result bool]
  template ny-test-case
  flags "--native-result-oracle=7"
  expect compile_and_run
  source ny <<'NY'
fn choose(bool ok, i64 a, i64 b) i64 {
  if ok { a } else { b }
}
choose(true, 7, 9)
NY
}
