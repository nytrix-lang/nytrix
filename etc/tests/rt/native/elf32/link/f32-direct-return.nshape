shape i386_elf32_object_link_run_f32_direct_return {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run f32 abi return]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-link-run-f32-direct-return.o"
  expect object_link_run_f32_3.75
  source ny <<'NY'
def f32 x = 1.5f32
def f32 y = 2.25f32
x + y
NY
}
