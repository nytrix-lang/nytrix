shape i386_elf32_object_link_run_memcpy_stub {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run pointer memcpy]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-link-run-memcpy-stub.o"
  expect object_link_run_i64_42
  source ny <<'NY'
use std.core

fn memcopy() i64 {
  def ptr src = malloc(8)
  def ptr dst = malloc(8)
  if src == nil || dst == nil { return 0 }
  store64_i(src, 42)
  memcpy(dst, src, 8)
  def i64 v = load64_i(dst)
  free(src)
  free(dst)
  v
}

memcopy()
NY
}
