shape i386_elf32_object_link_run_f64_compare_lt {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run f64 compare]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-link-run-f64-compare-lt.o"
  expect object_link_run_i64_1
  source ny <<'NY'
fn lt(f64 x, f64 y) bool {
  x < y
}

lt(1.5, 2.25)
NY
}
