shape x86_elf32_object_link_run_u32_return {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir link-run abi]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-native-elf32-link-run-u32-return.o"
  expect object_link_run_u32_4294967295
  source ny <<'NY'
fn ret_u32() u32 {
  4294967295
}
ret_u32()
NY
}
