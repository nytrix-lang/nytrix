shape i386_elf32_object_link_run_f64_call {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run f64 call]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-link-run-f64-call.o"
  expect object_link_run_f64_3.75
  source ny <<'NY'
fn val() f64 {
  3.75
}

val()
NY
}
