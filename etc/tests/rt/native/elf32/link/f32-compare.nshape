shape i386_elf32_object_link_run_f32_compare {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run f32 compare]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-link-run-f32-compare.o"
  expect object_link_run_i64_1
  source ny <<'NY'
def f32 a = 0.1
def f32 b = 0.2
def f32 c = a + b
def f32 t = 0.30000001
c == t
NY
}
