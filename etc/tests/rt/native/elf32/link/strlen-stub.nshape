shape i386_elf32_object_link_run_strlen_stub {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir link-run pointer strlen]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-link-run-elf32-strlen-stub.o"
  expect object_link_run_i64_42
  source ny <<'NY'
use std.core

extern {
  fn strlen(any p) i64
}

fn probe() i64 {
  def *int p = malloc(8)
  if p == nil { return 0 }
  store64_i(p, 6513249)
  def n = strlen(p)
  free(p)
  if n == 3 { 42 } else { 0 }
}

probe()
NY
}
