shape x86_elf32_link_archive {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir link-run archive]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-archive-link.o"
  expect object_link_run_i64_84
  link "etc/tests/rt/native/elf32/link/ar_helper32.a"
  source ny <<'NY'
extern "c" {
  fn ar_add42(i64 x) i64
}
def main = ar_add42(42)
NY
}
