shape x86_elf32_object_link_run_u8_return {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir link-run abi]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-native-elf32-link-run-u8-return.o"
  expect object_link_run_u8_255
  source ny <<'NY'
fn ret_u8() u8 {
  255
}
ret_u8()
NY
}
