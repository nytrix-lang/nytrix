shape i386_elf32_object_link_run_f64_cmp_all {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run f64 cmp]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-f64cmp-all.o"
  expect object_link_run_i64_1
  source ny <<'NY'
def a = 3.5
def b = 2.25
def c = 3.5
if a > b {
  if a >= c {
    if b < a {
      if b <= a {
        if a != b {
          if a == c {
            1
          } else { 0 }
        } else { 0 }
      } else { 0 }
    } else { 0 }
  } else { 0 }
} else { 0 }
NY
}
