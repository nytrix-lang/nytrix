shape i386_elf32_object_link_run_f32 {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run f32]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-link-run-f32.o"
  expect object_link_run_f64_0.30000001192092896
  source ny <<'NY'
def f32 a = 0.1
def f32 b = 0.2
def f64 c = a + b
c
NY
}
