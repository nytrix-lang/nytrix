shape i386_elf32_object_link_run_f64_params {
  family "runtime-native"
  generator "native"
  features [native object elf32 i386 x86 nyir link-run f64 call params]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-elf32-link-run-f64-params.o"
  expect object_link_run_f64_3.75
  source ny <<'NY'
fn add(f64 x, f64 y) f64 {
  x + y
}

add(1.5, 2.25)
NY
}
