shape x86_elf32_object_link_run_pointer_memory {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir link-run pointer memory]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-native-elf32-link-run-pointer-memory.o"
  expect object_link_run_i64_42
  source ny <<'NY'
use std.core

fn ptr_mem() i64 {
  def *int p = malloc(8)
  if p == nil { return 0 }
  store64_i(p, 41)
  def i64 v = load64_i(p)
  free(p)
  v + 1
}

ptr_mem()
NY
}
