shape i386_elf32_object_link_run_realloc_copy_stub {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir link-run pointer realloc]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-link-run-elf32-realloc-copy-stub.o"
  expect object_link_run_i64_42
  source ny <<'NY'
use std.core

fn probe() i64 {
  def *int p = malloc(8)
  if p == nil { return 0 }
  store64_i(p, 42)
  def *int q = realloc(p, 16)
  if q == nil { return 0 }
  def v = load64_i(q)
  free(q)
  v
}

probe()
NY
}
