shape x86_elf32_object_divmod {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir divmod]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-native-elf32-object-divmod.o"
  expect compile_and_run
  source ny <<'NY'
def a = 10
def b = 3
(a / b) + (a % b)
NY
}
