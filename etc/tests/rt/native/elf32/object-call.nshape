shape x86_elf32_object_call {
  family "runtime-native"
  generator "native"
  features [native object elf32 x86 nyir reloc call]
  template ny-test-case
  flags "--native-backend x86 -emit-only -o /tmp/nytrix-native-elf32-object-call.o"
  expect compile_and_run
  source ny <<'NY'
fn add3(i64 a, i64 b, i64 c) i64 {
  a + b + c
}

add3(4, 5, 6)
NY
}
