shape x86_64_macho_object_call_reloc {
  family "runtime-native"
  generator "native"
  features ["native", "object", "macho", "reloc", "x86_64", "nyir"]
  template ny-test-case
  flags "--native-backend x86_64 --host-triple x86_64-apple-darwin -emit-only -o /tmp/nytrix-native-macho64-object-call.o"
  expect compile_and_run
  source ny <<'NY'
fn add(i64 x, i64 y) i64 { x + y }
add(40, 2)
NY
}
