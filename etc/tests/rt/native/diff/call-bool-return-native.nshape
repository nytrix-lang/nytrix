shape diff_call_bool_return_native {
  family "runtime-native"
  generator "native"
  features [native x86_64 differential call bool]
  template ny-test-case
  flags "--native-backend x86_64"
  expect compile_and_run
  source ny <<'NY'
fn gt(i64 a, i64 b) bool { a > b }
if gt(5, 3) { 7 } else { 9 }
NY
}
