shape diff_call_bool_arg_vm {
  family "runtime-native"
  generator "native"
  features [native nyir vm differential call bool]
  template ny-test-case
  flags "--nyir-run"
  expect compile_and_run
  source ny <<'NY'
fn choose(bool ok, i64 a, i64 b) i64 { if ok { a } else { b } }
choose(true, 7, 9)
NY
}
