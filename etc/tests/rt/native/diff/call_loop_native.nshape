shape diff_call_loop_native {
  family "runtime-native"
  generator "native"
  features [native x86_64 differential call loop]
  template ny-test-case
  flags "--native-backend x86_64"
  expect compile_and_run
  source ny <<'NY'
fn inc(i64 x) i64 { x + 1 }
mut x = 0
while x < 4 { x = inc(x) }
x
NY
}
