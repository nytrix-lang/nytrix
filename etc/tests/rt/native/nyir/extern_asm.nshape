shape nyir_extern_asm {
  family "runtime-native"
  generator "native"
  features ["native", "nyir", "extern", "asm", "x86_64"]
  template ny-test-case
  flags "-emit-only --emit-asm=/dev/null --native-backend x86_64"
  expect compile_and_run
  source ny <<'NY'
extern {
  fn add(i64 a, i64 b) i64
}
add(2, 3)
NY
}
