shape nyir_range_fold {
  family "runtime-native"
  generator "native"
  features ["native", "nyir", "optimizer", "range"]
  template ny-test-case
  flags "--nyir-run --nyir-dump-stats"
  expect compile_and_run
  source ny <<'NY'
fn bounded(i64 x) i64 {
  if ((x & 255) / 2) < 128 { 1 } else { 2 }
}
bounded(123)
NY
}
