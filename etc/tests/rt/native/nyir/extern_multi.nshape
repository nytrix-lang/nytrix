shape nyir_extern_multi {
  family "runtime-native"
  generator "native"
  features ["native", "nyir", "extern", "call", "multi"]
  template ny-test-case
  flags "--nyir-dump --native-backend x86_64"
  expect compile_and_run
  source ny <<'NY'
extern {
  fn add(i64 a, i64 b) i64
  fn mul(i64 a, i64 b) i64
  fn neg(i64 a) i64
}
add(mul(3, 4), neg(1))
NY
}
