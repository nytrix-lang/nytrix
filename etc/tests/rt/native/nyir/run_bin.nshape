shape nyir_run_bin {
  family "runtime-native"
  generator "native"
  features ["native", "nyir", "vm", "binary"]
  template ny-test-case
  flags "--nyir-dump-bin=/tmp/nytrix-native-nyir-run-bin.nyir --nyir-run-bin=/tmp/nytrix-native-nyir-run-bin.nyir"
  expect compile_and_run
  source ny <<'NY'
9 * 7 - 5
NY
}
