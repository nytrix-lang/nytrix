shape nyir_metadata_bin {
  family "runtime-native"
  generator "native"
  features ["native", "nyir", "metadata", "binary"]
  template ny-test-case
  flags "--nyir-dump-bin=/tmp/nytrix-native-nyir-metadata-bin.nyir --nyir-metadata=/tmp/nytrix-native-nyir-metadata-bin.txt --nyir-metadata-bin=/tmp/nytrix-native-nyir-metadata-bin.nyir"
  expect compile_and_run
  source ny <<'NY'
1 + 2
NY
}
