shape nyir_metadata_report {
  family "runtime-native"
  generator "native"
  features ["native", "nyir", "metadata", "report"]
  template ny-test-case
  flags "--nyir-metadata=/tmp/nytrix-nyir-metadata-report.txt"
  expect compile_and_run
  source ny <<'NY'
fn add(i64 x, i64 y) i64 {
  x + y
}

mut acc = 0
for i in 0..3 {
  acc = add(acc, i)
}
acc
NY
}
