shape x86_target_deref {
  family "runtime-native"
  generator "native"
  features [native x86 target pointer deref]
  template ny-test-case
  flags "--native-backend x86 --emit-asm /tmp/nytrix-native-x86-deref.s"
  expect compile_and_run
  source ny <<'NY'
use std.core

fn ptr_deref() i64 {
  def *int p = malloc(8)
  if p == nil { return 0 }
  store64_i(p, 42)
  def i64 v = *p
  free(p)
  v
}

ptr_deref()
NY
}
