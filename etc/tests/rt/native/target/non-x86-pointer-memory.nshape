shape native_non_x86_pointer_memory {
  family "runtime-native"
  generator "native"
  features ["native", "target", "pointer", "memory", "non-x86"]
  template ny-test-case
  flags_matrix "--emit-asm=/tmp/nytrix-native-pointer-aarch64.s --native-backend aarch64; --emit-asm=/tmp/nytrix-native-pointer-riscv.s --native-backend riscv; --emit-asm=/tmp/nytrix-native-pointer-arm.s --native-backend arm --native-abi aapcs"
  expect compile_and_run
  source ny <<'NY'
use std.core

fn pointer_local() i64 {
  mut i64 value = 41
  def *int ptr = addr_of(value)
  store64_i(ptr, 42)
  load64_i(ptr)
}

pointer_local()
NY
}
