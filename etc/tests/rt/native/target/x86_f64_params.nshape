shape native_x86_f64_params {
  family "runtime-native"
  generator "native"
  features [native x86 oracle f64 call params]
  template ny-test-case
  flags "--native-backend x86 --native-result-oracle=4615626668101337088"
  expect compile_and_run
  source ny <<'NY'
fn add(f64 x, f64 y) f64 {
  x + y
}

add(1.5, 2.25)
NY
}
