shape native_x86_f32_call {
  family "runtime-native"
  generator "native"
  features [native x86 oracle f32 call]
  template ny-test-case
  flags "--native-backend x86 --native-result-oracle=4599075939685498880"
  expect compile_and_run
  source ny <<'NY'
fn add(f32 a, f32 b) f32 {
  a + b
}

def f64 y = add(0.1, 0.2)
y
NY
}
