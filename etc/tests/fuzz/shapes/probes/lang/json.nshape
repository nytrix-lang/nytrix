shape json {
  family "probe-suite"
  generator "stress"
  features ["ny", "lang"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.enc.json
fn dump(label, src){
   def r = json_try_decode(src)
   print(label + " ok=" + to_str(dict_get(r, "ok", false)) + " err=" + to_str(dict_get(r, "error", "")) + " pos=" + to_str(dict_get(r, "pos", -1)))
}
fn main(){
   dump("empty-str-object", "{\"copyright\":\"\",\"generator\":\"x\"}")
   dump("xmp-shape", "{\"@id\":\"\",\"dc:contributor\":{\"@set\":[\"a\",\"b\"]}}")
   dump("nested", "{\"a\":{\"b\":\"c\"},\"d\":1}")
}
NY
}
