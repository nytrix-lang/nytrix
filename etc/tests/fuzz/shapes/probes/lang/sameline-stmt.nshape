shape sameline_stmt {
  family "probe-suite"
  generator "stress"
  features ["ny", "lang"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
#!/bin/ny
use std.core
fn swap_if_needed(b, t){
   mut bb = b mut tt = t
   if(bb < tt){ def tmp = bb bb = tt tt = tmp } ; comment
   [bb, tt]
}
fn center(sw, sh, width, height){
   mut x = 0
   mut y = 0
   if(sw > 0 && sh > 0){ x = (sw - width) / 2 y = (sh - height) / 2 }
   [x, y]
}
fn main(){
   def a = swap_if_needed(0, 10)
   print("swap1=" + to_str(get(a,0,-1)) + "," + to_str(get(a,1,-1)))
   def b = swap_if_needed(10, 0)
   print("swap2=" + to_str(get(b,0,-1)) + "," + to_str(get(b,1,-1)))
   def c = center(1920, 1080, 960, 640)
   print("center1=" + to_str(get(c,0,-1)) + "," + to_str(get(c,1,-1)))
   def d = center(0, 0, 960, 640)
   print("center2=" + to_str(get(d,0,-1)) + "," + to_str(get(d,1,-1)))
}
main()
NY
}
