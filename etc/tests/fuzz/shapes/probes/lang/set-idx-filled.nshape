shape set_idx_filled {
  family "probe-suite"
  generator "stress"
  features ["ny", "lang"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
fn make_slots(){
   mut a = list(0)
   mut i = 0
   while(i < 2){
      a = append(a, false)
      i += 1
   }
   mut d = dict(0)
   dict_set(d, "x", 11)
   set_idx(a, 0, d)
   a
}
def r = make_slots()
def e = get(r, 0, 0)
print("r_is_list=" + to_str(is_list(r)))
print("r_len=" + to_str(len(r)))
print("e_is_dict=" + to_str(is_dict(e)))
print("e_raw=" + to_str(e))
print("e_x=" + to_str(dict_get(e, "x", -1)))
NY
}
