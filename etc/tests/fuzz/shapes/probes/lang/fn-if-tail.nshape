shape fn_if_tail {
  family "probe-suite"
  generator "stress"
  features ["ny", "lang"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
fn f1(){
   def raw = env("DOES_NOT_EXIST")
   if(is_str(raw) && len(raw) > 0){
      def v = atoi(raw)
      if(v > 0){ return v }
   }
   100
}
fn main(){
   print("f1=", f1())
}
main()
NY
}
