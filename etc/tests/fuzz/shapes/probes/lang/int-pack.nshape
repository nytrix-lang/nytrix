shape int_pack {
  family "probe-suite"
  generator "stress"
  features ["ny", "lang"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
def x = int(24)
def xr = to_int(x)
def n = int(-1)
def nr = to_int(n)
print("x=" + to_str(x))
print("xr=" + to_str(xr))
print("is_int_x=" + to_str(is_int(x)))
print("is_int_xr=" + to_str(is_int(xr)))
print("xr_plus0=" + to_str(xr + 0))
print("x_and=" + to_str(x & 0xffff))
print("xr_and=" + to_str(xr & 0xffff))
print("x_band=" + to_str(band(x, 0xffff)))
print("xr_band=" + to_str(band(xr, 0xffff)))
print("x_or0=" + to_str(x | 0))
print("xr_or0=" + to_str(xr | 0))
print("x_bor0=" + to_str(bor(x, 0)))
print("xr_bor0=" + to_str(bor(xr, 0)))
print("n=" + to_str(n))
print("nr=" + to_str(nr))
print("is_int_nr=" + to_str(is_int(nr)))
print("n_lt0=" + to_str(n < 0))
print("nr_lt0=" + to_str(nr < 0))
print("n_eqm1=" + to_str(n == -1))
print("nr_eqm1=" + to_str(nr == -1))
print("sentinel=" + to_str(0x80000000))
print("emit_expr=" + to_str((x >= 0) ? band(x, 0xffff) | (0 == 1 ? 0x10000 : 0) : 0x80000000))
print("emit_expr_bor=" + to_str((x >= 0) ? bor(band(x, 0xffff), (0 == 1 ? 0x10000 : 0)) : 0x80000000))
def uminus1 = 4294967295
print("uminus1=" + to_str(uminus1))
print("uminus1_ge0=" + to_str(uminus1 >= 0))
print("uminus1_and=" + to_str(uminus1 & 0xffff))
print("uminus1_band=" + to_str(band(uminus1, 0xffff)))
print("base_expr_u=" + to_str((uminus1 >= 0) ? band(uminus1, 0xffff) : 0x80000000))
print("base_expr_n=" + to_str((n >= 0) ? band(n, 0xffff) : 0x80000000))
NY
}
