shape mu {
  family "probe-suite"
  generator "stress"
  features ["ny", "math"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.util.parse.3d.gltf as gltf
use std.demo.scene as scene
use std.os.path as ospath
def p = ospath.resolve_repo_asset("etc/assets/models/gltf/tests/MultiUVTest/MultiUVTest.gltf")
def r = gltf.load_gltf_file(p)
print("loaded=" + to_str(is_dict(r)) + " err=" + to_str(dict_get(r, "error", "")))
if(is_dict(r) && !dict_has(r, "error")){
   def mats = gltf.gltf_material_infos(r)
   print("mats=" + to_str(len(mats)))
   if(len(mats) > 0){
      def m = get(mats, 0, 0)
      print("base_uri=" + to_str(dict_get(m, "base_color_uri", "")) + " base_tc=" + to_str(dict_get(m, "base_color_texcoord", -1)))
      print("emit_uri=" + to_str(dict_get(m, "emissive_uri", "")) + " emit_tc=" + to_str(dict_get(m, "emissive_texcoord", -1)))
   }
   def mat_records = scene.build_material_records(mats, ospath.resolve_repo_asset("etc/assets/models/gltf/tests/MultiUVTest"))
   def grp = gltf.gltf_to_mesh_group_indexed(r, 0, mat_records)
   print("grp_dict=" + to_str(is_dict(grp)) + " parts=" + to_str(len(dict_get(grp, "parts", []))))
   if(is_dict(grp)){
      def parts = dict_get(grp, "parts", [])
      if(len(parts) > 0){
         def part = get(parts, 0, 0)
         print("part_tex=" + to_str(dict_get(part, "tex_id", -999)) + " base_uv_xf1=" + to_str(dict_get(part, "base_uv_xf1", -999)) + " emissive_uv_xf1=" + to_str(dict_get(part, "emissive_uv_xf1", -999)))
         def slab = dict_get(part, "material_slab", 0)
         print("slab=" + to_str(!!slab))
         if(slab){
            print("slab_base_tex=" + to_str(load32(slab, 20)) + " slab_em_tex=" + to_str(load32(slab, 4)))
         }
      }
   }
}
NY
}
