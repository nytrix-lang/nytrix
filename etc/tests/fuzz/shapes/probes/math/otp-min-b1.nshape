shape otp_min_b1 {
  family "probe-suite"
  generator "stress"
  features ["ny", "math"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
module otp_min_b1(
   _otp_min,
   _otp_is_printable,
   _otp_lower,
   _otp_default_weight,
   _otp_freq_weight,
   _otp_insert_ranked,
   otp_hamming_distance,
   otp_guess_key_sizes,
   otp_score_english
)
use std.core
use std.math.bin
use std.math
fn _otp_min(a, b){ (a < b) ? a : b }
fn _otp_is_printable(b){ (b >= 32 && b <= 126) || b == 9 || b == 10 || b == 13 }
fn _otp_lower(b){ (b >= 65 && b <= 90) ? (b + 32) : b }
fn _otp_default_weight(b){
   def c = _otp_lower(b)
   if(c == 32){ return 130 }
   if(c == 101){ return 127 }
   if(c == 116){ return 91 }
   if(c == 97){ return 82 }
   if(c == 111){ return 75 }
   if(c == 105){ return 70 }
   if(c == 110){ return 67 }
   if(c == 115){ return 63 }
   if(c == 104){ return 61 }
   if(c == 114){ return 60 }
   if(c == 100){ return 43 }
   if(c == 108){ return 40 }
   if(c == 117){ return 28 }
   if(c == 99){ return 28 }
   if(c == 109){ return 24 }
   if(c == 102){ return 22 }
   if(c == 119){ return 20 }
   if(c == 103){ return 20 }
   if(c == 121){ return 20 }
   if(c == 112){ return 19 }
   if(c == 98){ return 15 }
   if(c == 118){ return 10 }
   if(c == 107){ return 8 }
   if(c == 106){ return 2 }
   if(c == 120){ return 2 }
   if(c == 113){ return 1 }
   if(c == 122){ return 1 }
   if(c >= 48 && c <= 57){ return 12 }
   if(c == 44 || c == 46 || c == 39 || c == 34 || c == 45 || c == 58 || c == 59){ return 16 }
   if(c == 9 || c == 10 || c == 13){ return 8 }
   if(c >= 33 && c <= 126){ return 1 }
   0
}
fn _otp_freq_weight(char_frequencies, b, char_floor){
   if(char_frequencies == nil){ return _otp_default_weight(b) }
   def c = _otp_lower(b)
   mut weight = dict_get(char_frequencies, c, nil)
   if(weight == nil){ weight = dict_get(char_frequencies, bytes_to_str([c]), nil) }
   if(weight == nil){ return char_floor }
   if(weight <= 0){ return char_floor }
   log10(weight)
}
fn _otp_insert_ranked(ranked, item){
   mut out = list(0)
   mut inserted = false
   mut i = 0
   while(i < len(ranked)){
      def cur = get(ranked, i)
      if(!inserted && get(item, 1) > get(cur, 1)){
         out = append(out, item)
         inserted = true
      }
      out = append(out, cur)
      i = i + 1
   }
   if(!inserted){ out = append(out, item) }
   out
}
fn otp_hamming_distance(a, b){
   def n = _otp_min(len(a), len(b))
   mut distance = 0
   mut i = 0
   while(i < n){
      distance = distance + bit_count(get(a, i) ^ get(b, i))
      i = i + 1
   }
   distance
}
fn otp_guess_key_sizes(ciphertexts, max_key_size=nil){
   def nct = len(ciphertexts)
   if(nct == 0){ return [] }
   mut max_len = 0
   mut ci = 0
   while(ci < nct){
      def clen = len(get(ciphertexts, ci))
      if(clen > max_len){ max_len = clen }
      ci = ci + 1
   }
   mut limit = (max_key_size == nil) ? max_len : max_key_size
   if(limit > max_len){ limit = max_len }
   if(limit < 2){ return [] }
   mut ranked = list(0)
   mut prev_distance = nil
   mut key_size = 2
   while(key_size <= limit){
      mut blocks = list(0)
      ci = 0
      while(ci < nct){
         def ct = get(ciphertexts, ci)
         mut off = 0
         while(off + key_size <= len(ct)){
            mut block = list(0)
            mut j = 0
            while(j < key_size){
               block = append(block, get(ct, off + j))
               j = j + 1
            }
            blocks = append(blocks, block)
            off = off + key_size
         }
         ci = ci + 1
      }
      if(len(blocks) >= 2){
         mut total = 0
         mut bi = 0
         while(bi + 1 < len(blocks)){
            total = total + otp_hamming_distance(get(blocks, bi), get(blocks, bi + 1))
            bi = bi + 1
         }
         def distance = (float(total) / float(len(blocks) - 1)) / float(key_size)
         if(prev_distance != nil){
            ranked = _otp_insert_ranked(ranked, [key_size, prev_distance - distance])
         }
         prev_distance = distance
      }
      key_size = key_size + 1
   }
   mut out = list(0)
   mut i = 0
   while(i < len(ranked)){
      out = append(out, get(get(ranked, i), 0))
      i = i + 1
   }
   out
}
fn otp_score_english(bytes, char_frequencies=nil, char_floor=-5){
   mut score = 0
   mut i = 0
   while(i < len(bytes)){
      def b = get(bytes, i)
      if(!_otp_is_printable(b)){ return nil }
      score = score + _otp_freq_weight(char_frequencies, b, char_floor)
      i = i + 1
   }
   score
}
if(comptime{__main()}){
   print("ok b1")
}
NY
}
