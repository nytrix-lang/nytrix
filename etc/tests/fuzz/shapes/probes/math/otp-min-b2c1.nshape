shape otp_min_b2c1 {
  family "probe-suite"
  generator "stress"
  features ["ny", "math"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
module otp_min_b2c1(f)
use std.core
fn f(ciphertexts, key_size=nil){
   def sizes = (key_size == nil) ? [3] : [key_size]
   mut best_key = nil
   mut si = 0
   while(si < len(sizes)){
      def ks = get(sizes, si)
      mut key = list(0)
      mut ok = true
      mut i = 0
      while(i < ks && ok){
         def kb = 0
         if(kb == nil){ ok = false } else { key = append(key, kb) }
         i = i + 1
      }
      if(ok){
         best_key = key
      }
      si = si + 1
   }
   best_key
}
if(comptime{__main()}){
   print("ok c1")
}
NY
}
