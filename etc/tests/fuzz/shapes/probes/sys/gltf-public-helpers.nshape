shape gltf-public-helpers {
  family "probe-suite"
  generator "stress"
  features ["ny", "sys"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.math.parse.3d.gltf as gltf
def inline_doc = "{\"asset\":{\"version\":\"2.0\"},\"scenes\":[{\"nodes\":[]}],\"nodes\":[],\"meshes\":[],\"materials\":[],\"animations\":[]}"
def parsed = gltf.parse_gltf_str(inline_doc, "tmp/test/platform/ui")
assert(is_dict(parsed), "inline gltf parses to dict")
assert(!parsed.contains("error"), "inline gltf has no validation error")
assert(gltf.gltf_mesh_count(parsed) == 0, "inline gltf mesh count")
assert(gltf.gltf_material_infos(parsed).len == 0, "inline gltf material list")
assert(gltf.gltf_animation_count(parsed) == 0, "inline gltf animation count")
assert(gltf.gltf_required_extension_failures(parsed).len == 0, "inline gltf required extension failures")
def cube = gltf.load_gltf_file("tmp/assets/models/gltf/tests/Cube/Cube.gltf")
assert(is_dict(cube), "cube gltf loads")
assert(!cube.contains("error"), "cube gltf has no load error")
assert(gltf.gltf_mesh_count(cube) > 0, "cube mesh count")
assert(is_list(gltf.gltf_material_infos(cube)), "cube material infos")
assert(gltf.gltf_material_infos_limited(cube, 1).len <= 1, "limited material infos")
assert(is_list(gltf.gltf_material_texture_uris(cube)), "material texture URI list")
assert(gltf.gltf_required_extension_failures(cube).len == 0, "cube has no unsupported required extensions")
def cube_parts = gltf.gltf_mesh_to_vertex_buffers(cube, 0)
assert(is_list(cube_parts), "cube vertex buffer parts returns list")
assert(cube_parts.len > 0, "cube vertex buffer parts has data")
def cube_part0 = cube_parts[0]
assert(is_dict(cube_part0), "cube vertex buffer part is dict")
assert(cube_part0.get("ptr", 0) != 0, "cube vertex buffer part has ptr")
assert(int(cube_part0.get("count", 0)) > 0, "cube vertex buffer part has vertices")
def cube_vb = gltf.gltf_to_vertex_buffer(cube, 0)
assert(is_dict(cube_vb), "cube combined vertex buffer returns dict")
assert(!cube_vb.contains("error"), "cube combined vertex buffer has no error")
assert(cube_vb.get("ptr", 0) != 0, "cube combined vertex buffer has ptr")
assert(int(cube_vb.get("count", 0)) > 0, "cube combined vertex buffer has vertices")
def cube_group = gltf.gltf_to_mesh_group_indexed(cube)
assert(is_dict(cube_group), "cube indexed mesh group returns dict")
def cube_group_parts = cube_group.get("parts", [])
assert(is_list(cube_group_parts), "cube indexed mesh group parts list")
assert(cube_group_parts.len > 0, "cube indexed mesh group has parts")
def cube_group_part0 = cube_group_parts[0]
assert(is_dict(cube_group_part0), "cube indexed mesh group part is dict")
assert(cube_group_part0.get("vptr", 0) != 0, "cube indexed part has vertex ptr")
assert(cube_group_part0.get("iptr", 0) != 0, "cube indexed part has index ptr")
assert(int(cube_group_part0.get("vcnt", 0)) > 0, "cube indexed part has vertices")
assert(int(cube_group_part0.get("icnt", 0)) > 0, "cube indexed part has indices")
def cube_summary = gltf.gltf_scene_feature_summary(cube)
assert(is_dict(cube_summary), "cube feature summary")
assert(int(cube_summary.get("material_count", -1)) >= 0, "cube summary material count")
assert(is_dict(gltf.gltf_extensions_report(cube)), "cube extension report")
def animated = gltf.load_gltf_file("tmp/assets/models/gltf/tests/AnimatedTriangle/AnimatedTriangle.gltf")
assert(is_dict(animated), "animated gltf loads")
assert(!animated.contains("error"), "animated gltf has no load error")
assert(gltf.gltf_animation_count(animated) > 0, "animated triangle animation count")
def anim_info = gltf.gltf_animation_info(animated, 0)
assert(is_dict(anim_info), "animation info returns dict")
assert(float(anim_info.get("duration", -1.0)) >= 0.0, "animation duration is non-negative")
def anim_sample = gltf.gltf_sample_animation(animated, 0, 0.25)
assert(is_dict(anim_sample), "animation sample returns dict")
def anim_merged = gltf.gltf_sample_animation_merged(animated, 0.25)
assert(is_dict(anim_merged), "merged animation sample returns dict")
def anim_mats = gltf.gltf_rebuild_animated_mats(animated, anim_sample)
assert(is_dict(anim_mats), "animated mats rebuild returns dict")
def morph_apply = gltf.gltf_apply_morph_weights(animated, anim_sample)
assert(is_list(morph_apply), "morph apply returns tuple list")
assert(morph_apply.len == 2, "morph apply tuple length")
def skin = gltf.load_gltf_file("tmp/assets/models/gltf/tests/SimpleSkin/SimpleSkin.gltf")
assert(is_dict(skin), "skin gltf loads")
assert(!skin.contains("error"), "skin gltf has no load error")
assert(gltf.gltf_skin_count(skin) > 0, "skin count")
assert(is_dict(gltf.gltf_skin_info(skin, 0)), "skin info returns dict")
assert(!gltf.gltf_free_skin_mats_cache(0), "free skin cache rejects non-dict")
assert(gltf.gltf_free_data(cube), "cube data frees")
assert(gltf.gltf_free_data(animated), "animated data frees")
assert(gltf.gltf_free_data(skin), "skin data frees")
NY
}
