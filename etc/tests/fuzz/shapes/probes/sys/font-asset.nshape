shape font-asset {
  family "probe-suite"
  generator "stress"
  features ["ny", "sys"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.core.error
use std.os
use std.os.ui.font.truetype as ttf
fn probe(path){
   print("font " + path)
   if !file_exists(path) {
      print("  missing")
      return
   }
   def info = ttf.load_path(path, 0)
   assert(info != 0, "load " + path)
   def gi_a = ttf.get_glyph_index(info, 65)
   def gi_e = ttf.get_glyph_index(info, 69)
   def gi_q = ttf.get_glyph_index(info, 63)
   print("  gi A=" + to_str(gi_a) + " E=" + to_str(gi_e) + " ?=" + to_str(gi_q))
   def scale = ttf.scale_for_pixel_height(info, 32.0)
   def bm = ttf.get_glyph_bitmap(info, scale, scale, gi_a)
   assert(bm != 0, "bitmap " + path)
   def w = bm.get("width", 0)
   def h = bm.get("height", 0)
   def data = bm.get("data", 0)
   print("  bitmap=" + to_str(w) + "x" + to_str(h) + " xoff=" + to_str(bm.get("xoff", 0)) + " yoff=" + to_str(bm.get("yoff", 0)))
   mut y = 0
   while y < h {
      mut line = "  "
      mut x = 0
      while x < w {
         def a = load8(data, (y * w + x) * 4 + 3)
         line += a > 180 ? "#" : (a > 40 ? "+" : ".")
         x += 1
      }
      print(line)
      y += 1
   }
   ttf.unload(info)
}
probe("etc/assets/fonts/jetbrains.ttf")
probe("etc/assets/fonts/maplemono.ttf")
probe("etc/assets/fonts/monocraft.ttf")
probe("/usr/share/fonts/TTF/DejaVuSansMono.ttf")
NY
}
