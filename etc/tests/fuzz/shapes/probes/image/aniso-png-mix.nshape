shape aniso_png_mix {
  family "probe-suite"
  generator "stress"
  features ["ny", "image"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.util.parse.image as img
def FILES = [
   "etc/assets/models/gltf/tests/CompareAnisotropy/Compare_Anisotropy_img0.jpg",
   "etc/assets/models/gltf/tests/CompareAnisotropy/Compare_Anisotropy_img1.png",
   "etc/assets/models/gltf/tests/CompareAnisotropy/Compare_Anisotropy_img2.jpg",
   "etc/assets/models/gltf/tests/CompareAnisotropy/Compare_Anisotropy_img3.png",
   "etc/assets/models/gltf/tests/CompareAnisotropy/Compare_Anisotropy_img4.png",
   "etc/assets/models/gltf/tests/AnisotropyRotationTest/AnisoDonutLabels.png"
]
fn main(){
   mut round = 0
   while(round < 50){
      mut i = 0
      while(i < len(FILES)){
         def path = to_str(get(FILES, i, ""))
         def im = img.load(path)
         if(!im){
            print("load failed round=" + to_str(round) + " idx=" + to_str(i) + " path=" + path)
            return 1
         }
         i += 1
      }
      print("round " + to_str(round))
      round += 1
   }
   print("done")
   0
}
NY
}
