shape mandarin_png {
  family "probe-suite"
  generator "stress"
  features ["ny", "image"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
#!/bin/ny
use std.core
use std.util.parse.image as image
fn _check(path){
   def img = image.load(path)
   if(!img){
      print("[probe] fail " + path)
      return 1
   }
   print("[probe] ok " + path + " " + to_str(dict_get(img, "width", 0)) + "x" + to_str(dict_get(img, "height", 0)))
   0
}
fn main(){
   def a = _check("/tmp/mon.png")
   def b = _check("/tmp/mdt.png")
   if(a != 0 || b != 0){ return 1 }
   0
}
main()
NY
}
