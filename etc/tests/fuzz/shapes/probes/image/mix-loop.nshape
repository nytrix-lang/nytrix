shape mix_loop {
  family "probe-suite"
  generator "stress"
  features ["ny", "image"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.util.parse.image as img
def FILES = [
   "etc/assets/models/gltf/tests/PointLightIntensityTest/LampColorNames.png",
   "etc/assets/models/gltf/tests/TextureCoordinateTest/TextureCoordinateTemplate.png",
   "etc/assets/models/gltf/tests/TextureEncodingTest/0_136_0_gamma.png",
   "etc/assets/models/gltf/tests/TextureEncodingTest/SlotLabels.png",
   "etc/assets/models/gltf/tests/TextureTransformTest/Arrow.png",
   "etc/assets/models/gltf/tests/VertexColorTest/VertexColorChecks.png",
   "etc/assets/models/gltf/tests/MorphPrimitivesTest/uv_texture.jpg"
]
fn main(){
   mut round = 0
   while(round < 80){
      mut i = 0
      while(i < len(FILES)){
         def path = to_str(get(FILES, i, ""))
         def im = img.load(path)
         if(!im){
            print("load failed round=" + to_str(round) + " idx=" + to_str(i) + " path=" + path)
            return 1
         }
         i += 1
      }
      if((round % 10) == 0){
         print("round " + to_str(round))
      }
      round += 1
   }
   print("done")
   0
}
NY
}
