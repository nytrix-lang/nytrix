use std.core
fn fold0(int: x): int {
   mut int: y = (((x * 3) + 19) % 97)
   if((y % 2) == 0){
      y += (x % 11)
   } else {
      y -= (x % 7)
   }
   return y
}
fn fold1(int: x): int {
   def int: y = fold0((x + 5))
   if(y > 40){
      return (y - 13)
   } else {
      return (y + 17)
   }
}
mut int: acc = 0
mut int: i = 0
while(i < 32){
   acc += fold1((i + (acc % 5)))
   if((acc % 4) == 1){
      acc += fold0(i)
   }
   i += 1
}
print(acc)
