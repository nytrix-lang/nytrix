   if(((state + i) % 5) == 0){
      state = ((state + 18) % 211)
      acc += state
   } else {
      if((i % 2) == 0){
         state = (((state * 3) + i) % 211)
      } else {
         state = ((state + (i * 2)) % 211)
      }
      acc -= (state % 23)
   }
