use std.core
mut work = [15, 27, 8, 22, 4]
mut int: acc = 0
mut int: i = 0
while(i < 32){
   def int: idx = (((i * 5) + 8) % 5)
   def int: next = (((get(work, idx, 0) + i) + acc) % 127)
   work = set_idx(work, idx, next)
   acc += (get(work, idx, 0) - (i % 3))
   i += 1
}
print(acc)
