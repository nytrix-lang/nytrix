use std.core
def data = [29, 4, 26, 3, 17, 18, 20]
mut int: acc = 0
mut int: i = 0
while(i < 32){
   def int: idx = (i % 10)
   def int: got = get(data, idx, 13)
   if((idx < 0) || (idx >= len(data))){
      acc += (got - i)
   } else {
      acc += (got + (i % 5))
   }
   i += 1
}
print(acc)
