use std.core
def src = [26, 6, 23, 24, 20]
mut dst = [0, 0, 0, 0, 0]
mut int: acc = 0
mut int: i = 0
while(i < 5){
   def int: v = (get(src, i, 0) + 15)
   dst = set_idx(dst, i, ((v + (i * 4)) % 149))
   i += 1
}
mut int: j = 0
while(j < 31){
   def int: idx = ((j + 18) % 5)
   acc += get(dst, idx, 0)
   if((j % 4) == 3){
      dst = set_idx(dst, idx, ((get(dst, idx, 0) + acc) % 149))
   }
   j += 1
}
print(acc)
