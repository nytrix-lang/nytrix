use std.core
fn mix(int: x, int: y): int {
   mut int: z = (((x * 10) + (y * 3)) % 173)
   if(z > 80){
      z -= (x % 17)
   } else {
      z += (y % 19)
   }
   return z
}
mut int: acc = 0
mut int: i = 0
while(i < 8){
   mut int: j = 0
   while(j < 4){
      acc += mix((i + j), (acc + 3))
      if(((i + j) % 3) == 1){
         acc -= (mix(j, i) % 11)
      }
      j += 1
   }
   i += 1
}
print(acc)
