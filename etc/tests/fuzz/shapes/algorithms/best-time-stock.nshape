shape best-time-stock {
  family "training-kernels"
  generator "torture"
  features ["training-kernel", "reusable", "ny", "array", "scan", "minmax", "state"]
  template reusable-ny-kernel
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.core.error
use std.core.reflect
use std.os.time
fn gen_prices(n){
   mut a = list(0)
   mut x = 987654321
   mut i = 0
   while(i < n){
      a = append(a, 0)
      i += 1
   }
   i = 0
   while(i < n){
      x = (x * 1664525 + 1013904223) & 2147483647
      set_idx(a, i, (x % 100000) + 1)
      i += 1
   }
   return a
}
fn best_profit(prices){
   mut mn = get(prices, 0)
   mut best = 0
   mut i = 1
   while(i < len(prices)){
      def p = get(prices, i)
      if(p < mn){ mn = p }
      def prof = p - mn
      if(prof > best){ best = prof }
      i += 1
   }
   return best
}
def arr = gen_prices(160000)
mut checksum = 0
def t0 = ticks()
mut r = 0
while(r < 32){
   checksum += best_profit(arr)
   r += 1
}
def t1 = ticks()
print("RESULT best_time_stock ", checksum, " ", t1 - t0)
NY
}
