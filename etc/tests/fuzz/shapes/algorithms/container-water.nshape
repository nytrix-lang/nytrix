shape container-water {
  family "training-kernels"
  generator "torture"
  features ["training-kernel", "reusable", "ny", "two-pointer", "array", "max-scan"]
  template reusable-ny-kernel
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.core.error
use std.core.reflect
use std.os.time
fn gen_h(n){
   mut a = list(0)
   mut x = 13579
   mut i = 0
   while(i < n){
      a = append(a, 0)
      i += 1
   }
   i = 0
   while(i < n){
      x = (x * 1103515245 + 12345) & 2147483647
      set_idx(a, i, (x % 10000) + 1)
      i += 1
   }
   return a
}
fn max_area(h){
   mut l = 0
   mut r = len(h) - 1
   mut best = 0
   while(l < r){
      def lh = get(h, l)
      def rh = get(h, r)
      def ht = (lh < rh) ? lh : rh
      def area = (r - l) * ht
      if(area > best){ best = area }
      if(lh < rh){ l += 1 } else { r -= 1 }
   }
   return best
}
def arr = gen_h(200000)
mut checksum = 0
def t0 = ticks()
mut r = 0
while(r < 28){
   checksum += max_area(arr)
   r += 1
}
def t1 = ticks()
print("RESULT container_water ", checksum, " ", t1 - t0)
NY
}
