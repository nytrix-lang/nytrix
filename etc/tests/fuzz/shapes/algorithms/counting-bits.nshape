shape counting-bits {
  family "training-kernels"
  generator "torture"
  features ["training-kernel", "reusable", "ny", "bitwise", "dynamic-programming", "array"]
  template reusable-ny-kernel
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time
fn zero_list(n){
   mut out = list(n)
   mut i = 0
   while(i < n){
      out = append(out, 0)
      i += 1
   }
   out
}
def N = 60000
def dp = zero_list(N + 1)
fn count_bits_upto(dp, n){
   set_idx(dp, 0, 0)
   mut i = 1
   while(i <= n){
      set_idx(dp, i, get(dp, i >> 1) + (i & 1))
      i += 1
   }
   mut s = 0
   i = 0
   while(i <= n){
      s += get(dp, i)
      i += 1
   }
   return s
}
mut checksum = 0
def t0 = ticks()
mut r = 0
while(r < 120){
   checksum += count_bits_upto(dp, N)
   r += 1
}
def t1 = ticks()
print("RESULT counting_bits ", checksum, " ", t1 - t0)
NY
}
