shape jump-game {
  family "training-kernels"
  generator "torture"
  features ["training-kernel", "reusable", "ny", "greedy", "array", "reachability"]
  template reusable-ny-kernel
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.core.error
use std.core.reflect
use std.os.time
fn gen_jump(n){
   mut a = list(0)
   mut x = 11223344
   mut i = 0
   while(i < n){
      a = append(a, 0)
      i += 1
   }
   i = 0
   while(i < n){
      x = (x * 1103515245 + 12345) & 2147483647
      set_idx(a, i, (x % 6) + 1)
      i += 1
   }
   set_idx(a, n - 1, 0)
   return a
}
fn gen_blocked(n){
   def a = gen_jump(n)
   set_idx(a, 0, 0)
   a
}
fn can_jump(nums){
   mut far = 0
   mut i = 0
   while(i < len(nums)){
      if(i > far){ return false }
      def cand = i + get(nums, i)
      if(cand > far){ far = cand }
      i += 1
   }
   return true
}
def arr = gen_jump(240000)
def blocked = gen_blocked(240000)
mut checksum = 0
def t0 = ticks()
mut r = 0
while(r < 40){
   checksum += can_jump(arr) ? 3 : 0
   checksum += can_jump(blocked) ? 0 : 5
   r += 1
}
def t1 = ticks()
print("RESULT jump_game ", checksum, " ", t1 - t0)
NY
}
