shape reverse-bits {
  family "training-kernels"
  generator "torture"
  features ["training-kernel", "reusable", "ny", "bitwise", "scalar", "loop"]
  template reusable-ny-kernel
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time
fn rev32(x){
   mut v = x
   mut r = 0
   mut i = 0
   while(i < 32){
      r = (r << 1) | (v & 1)
      v = v >> 1
      i += 1
   }
   return r & 4294967295
}
mut checksum = 0
def t0 = ticks()
mut i = 1
while(i < 3500000){
   checksum += rev32(i * 2654435761)
   i += 1
}
def t1 = ticks()
print("RESULT reverse_bits ", checksum, " ", t1 - t0)
NY
}
