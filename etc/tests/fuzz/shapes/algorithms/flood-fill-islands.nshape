shape flood-fill-islands {
  family "training-kernels"
  generator "torture"
  features ["training-kernel", "reusable", "ny", "grid", "queue", "mutation"]
  template reusable-ny-kernel
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time
fn zero_list(n){
   mut out = list(0)
   mut i = 0
   while(i < n){
      out = append(out, 0)
      i += 1
   }
   out
}
fn gen_grid(w, h){
   def n = w * h
   mut g = zero_list(n)
   mut x = 987654321
   mut i = 0
   while(i < n){
      x = (x * 1103515245 + 12345) & 2147483647
      def ridge = (i % w == 0 || i % w == w - 1 || i < w || i >= n - w) ? 0 : 1
      def land = ((x % 100) < 47 || (i % 17) == 0) && ridge == 1 ? 1 : 0
      set_idx(g, i, land)
      i += 1
   }
   g
}
fn copy_grid(src){
   def n = len(src)
   mut out = zero_list(n)
   mut i = 0
   while(i < n){
      set_idx(out, i, get(src, i))
      i += 1
   }
   out
}
fn push_if_land(g, q, w, h, pos, head){
   if(pos < 0 || pos >= w * h){ return head }
   if(get(g, pos) == 0){ return head }
   set_idx(g, pos, 0)
   set_idx(q, head, pos)
   head + 1
}
fn count_islands(src, w, h){
   mut g = copy_grid(src)
   def n = len(g)
   mut q = zero_list(n)
   mut islands = 0
   mut checksum = 0
   mut i = 0
   while(i < n){
      if(get(g, i) != 0){
         islands += 1
         mut tail = 0
         mut head = 0
         set_idx(g, i, 0)
         set_idx(q, head, i)
         head += 1
         while(tail < head){
            def p = get(q, tail)
            tail += 1
            checksum += p & 255
            def x = p % w
            def y = p / w
            if(x > 0){ head = push_if_land(g, q, w, h, p - 1, head) }
            if(x + 1 < w){ head = push_if_land(g, q, w, h, p + 1, head) }
            if(y > 0){ head = push_if_land(g, q, w, h, p - w, head) }
            if(y + 1 < h){ head = push_if_land(g, q, w, h, p + w, head) }
         }
      }
      i += 1
   }
   islands * 1000003 + checksum
}
def W = 96
def H = 80
def base = gen_grid(W, H)
mut checksum = 0
def t0 = ticks()
mut r = 0
while(r < 70){
   checksum += count_islands(base, W, H)
   r += 1
}
def t1 = ticks()
print("RESULT flood_fill_islands ", checksum, " ", t1 - t0)
NY
}
