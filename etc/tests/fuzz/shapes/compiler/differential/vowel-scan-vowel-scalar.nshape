shape vowel-scan-vowel_scalar {
  family "compiler-suite"
  generator "stress"
  features ["ny", "differential"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
fn vowel_scalar(ptr: p, int: n): int {
   mut one = 0
   mut i = 0
   while(i < n){
      def c = load8(p, i)
      if(c == 97 || c == 101 || c == 105 || c == 111 || c == 117){
         one += 3
      } else {
         one += 1
      }
      i += 1
   }
   one
}
fn main(): int {
   def n = 8192
   def rounds = 300
   def p = malloc_raw(n + 1)
   mut i = 0
   while(i < n){
      store8(p, ((i * 131 + (i / 8) + 17) % 96) + 32, i)
      i += 1
   }
   mut total = 0
   mut r = 0
   while(r < rounds){
      total += vowel_scalar(p, n)
      r += 1
   }
   print(total)
   free_raw(p)
   return 0
}
NY
}
