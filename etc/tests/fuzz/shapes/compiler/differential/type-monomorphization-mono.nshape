shape type-monomorphization-mono {
  family "compiler-suite"
  generator "stress"
  features ["ny", "differential"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
fn mix(a, b){
   ((a * 1664525) + b + 1013904223) & 0x7fffffff
}
fn run(int: n): int {
   mut int: acc = 1
   mut int: i = 0
   while(i < n){
      acc = mix(acc, i)
      i += 1
   }
   acc
}
print(run(2000000))
NY
}
