shape sieve {
  family "perf-real"
  generator "stress"
  features ["perf", "c-vs-ny", "checksum"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time
def N = 60000
;; Sieve of Eratosthenes (Benchmark)
fn sieve(n) {
   if n < 2 { return 0 }
   def size = (n >> 1) + 1
   def flags = malloc(size)
   mut i = 0
   while i < size {
      store8(flags, 1, i)
      i += 1
   }
   mut count = 1
   mut p = 3
   while p * p <= n {
      if load8(flags, p >> 1) {
         def sq = p * p
         mut mul = sq
         while mul <= n {
            store8(flags, 0, mul >> 1)
            mul += p * 2
         }
      }
      p += 2
   }
   i = p
   while i <= n {
      if load8(flags, i >> 1) { count += 1 }
      i += 2
   }
   free(flags)
   return count
}
print(f"Benchmarking Sieve up to {to_str(N)}")
def t0 = ticks()
def r = sieve(N)
def t1 = ticks()
print(f"Primes: {to_str(r)}")
print(f"Time: {to_str((t1 - t0) / 1000000)} ms")
NY
  source c <<'C'
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

static int64_t now_ns(void) {
    return (int64_t)((double)clock() * 1000000000.0 / (double)CLOCKS_PER_SEC);
}

static int sieve(int n) {
    if (n < 2) return 0;
    int size = (n >> 1) + 1;
    unsigned char *flags = (unsigned char *)malloc((size_t)size);
    if (!flags) exit(2);
    memset(flags, 1, (size_t)size);
    int count = 1;
    for (int p = 3; p * p <= n; p += 2) {
        if (flags[p >> 1]) {
            for (int mul = p * p; mul <= n; mul += p * 2) flags[mul >> 1] = 0;
        }
    }
    for (int i = 3; i <= n; i += 2) if (flags[i >> 1]) count++;
    free(flags);
    return count;
}
int main(void) {
    int64_t start = now_ns();
    int r = sieve(60000);
    int64_t end = now_ns();
    printf("checksum=%lld\n", (long long)r);
    if (end <= start) end = start + 1;
    printf("elapsed_ns=%lld\n", (long long)(end - start));
    return 0;
}
C
}
