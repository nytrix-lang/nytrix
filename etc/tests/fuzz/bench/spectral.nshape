shape spectral {
  family "perf-real"
  generator "stress"
  features ["perf", "c-vs-ny", "checksum"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.math.float (float)
use std.os.time
def N = 64
def ITERS = 2
;; Spectral Norm (Benchmark)
mut u = list(N)
mut v = list(N)
mut tmp = list(N)
mut i = 0
while i < N {
   u = u.append(1.0)
   v = v.append(0.0)
   tmp = tmp.append(0.0)
   i += 1
}
fn A(i, j) {
   def ij = i + j
   return 1.0 / (((ij * (ij + 1)) >> 1) + i + 1)
}
fn mul_Av(x, out) {
   mut i = 0
   while i < N {
      mut sum = 0.0
      mut j = 0
      while j < N {
         sum += A(i, j) * x.get(j)
         j += 1
      }
      out.set(i, sum)
      i += 1
   }
}
fn mul_Atv(x, out) {
   mut i = 0
   while i < N {
      mut sum = 0.0
      mut j = 0
      while j < N {
         sum += A(j, i) * x.get(j)
         j += 1
      }
      out.set(i, sum)
      i += 1
   }
}
def start = ticks()
i = 0
while i < ITERS {
   mul_Av(u, tmp)
   mul_Atv(tmp, v)
   mul_Av(v, tmp)
   mul_Atv(tmp, u)
   i += 1
}
mut vbv = 0.0
mut vv = 0.0
i = 0
while i < N {
   vbv += u.get(i) * v.get(i)
   vv += v.get(i) * v.get(i)
   i += 1
}
def res = __flt_sqrt(float(vbv / vv))
def end = ticks()
print("Result:", res)
print("Time:", (end - start) / 1000000, "ms")
NY
  source c <<'C'
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

static int64_t now_ns(void) {
    return (int64_t)((double)clock() * 1000000000.0 / (double)CLOCKS_PER_SEC);
}

static double sqrt_approx(double x) {
    if (x <= 0.0) return 0.0;
    double g = x > 1.0 ? x : 1.0;
    for (int i = 0; i < 24; i++) g = 0.5 * (g + x / g);
    return g;
}
static double A(int i, int j) {
    int ij = i + j;
    return 1.0 / (double)(((ij * (ij + 1)) >> 1) + i + 1);
}
static void mul_Av(const double *x, double *out, int n) {
    for (int i = 0; i < n; i++) {
        double sum = 0.0;
        for (int j = 0; j < n; j++) sum += A(i, j) * x[j];
        out[i] = sum;
    }
}
static void mul_Atv(const double *x, double *out, int n) {
    for (int i = 0; i < n; i++) {
        double sum = 0.0;
        for (int j = 0; j < n; j++) sum += A(j, i) * x[j];
        out[i] = sum;
    }
}
int main(void) {
    const int n = 64, iters = 2;
    double *u = (double *)malloc((size_t)n * sizeof(double));
    double *v = (double *)calloc((size_t)n, sizeof(double));
    double *tmp = (double *)calloc((size_t)n, sizeof(double));
    if (!u || !v || !tmp) return 2;
    for (int i = 0; i < n; i++) u[i] = 1.0;
    int64_t start = now_ns();
    for (int i = 0; i < iters; i++) {
        mul_Av(u, tmp, n); mul_Atv(tmp, v, n);
        mul_Av(v, tmp, n); mul_Atv(tmp, u, n);
    }
    double vbv = 0.0, vv = 0.0;
    for (int i = 0; i < n; i++) { vbv += u[i] * v[i]; vv += v[i] * v[i]; }
    double res = sqrt_approx(vbv / vv);
    int64_t end = now_ns();
    free(u); free(v); free(tmp);
    printf("checksum=%lld\n", (long long)(res * 1000000000.0));
    printf("result=%.12f\n", res);
    if (end <= start) end = start + 1;
    printf("elapsed_ns=%lld\n", (long long)(end - start));
    return 0;
}
C
}
