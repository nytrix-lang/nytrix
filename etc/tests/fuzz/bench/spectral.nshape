shape spectral {
  family "perf-real"
  generator "stress"
  features ["perf", "c-vs-ny", "checksum"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.core.tbuf
use std.math.float (float)
use std.os.time
def N = 64
def ITERS = 2
;; Spectral Norm (Benchmark)
def u = f64buf_new(N)
def v = f64buf_new(N)
def tmp = f64buf_new(N)
mut i = 0
while i < N {
   f64buf_store(u, i, 1.0)
   f64buf_store(v, i, 0.0)
   f64buf_store(tmp, i, 0.0)
   i += 1
}
fn mul_Av(ptr x, ptr out) ptr {
   mut i = 0
   while i < N {
      mut sum = 0.0
      mut j = 0
      while j < N {
         def ij = i + j
         def aij = 1.0 / float(((ij * (ij + 1)) >> 1) + i + 1)
         sum += aij * f64buf_load(x, j)
         j += 1
      }
      f64buf_store(out, i, sum)
      i += 1
   }
   out
}
fn mul_Atv(ptr x, ptr out) ptr {
   mut i = 0
   while i < N {
      mut sum = 0.0
      mut j = 0
      while j < N {
         def ij = i + j
         def aji = 1.0 / float(((ij * (ij + 1)) >> 1) + j + 1)
         sum += aji * f64buf_load(x, j)
         j += 1
      }
      f64buf_store(out, i, sum)
      i += 1
   }
   out
}
def start = ticks()
i = 0
while i < ITERS {
   mul_Av(u, tmp)
   mul_Atv(tmp, v)
   mul_Av(v, tmp)
   mul_Atv(tmp, u)
   i += 1
}
mut vbv = 0.0
mut vv = 0.0
mut checksum = 0
i = 0
while i < N {
   def ui = f64buf_load(u, i)
   def vi = f64buf_load(v, i)
   vbv += ui * vi
   vv += vi * vi
   if i < 16 {
      checksum += (i + 1) * 97
      if checksum > 90000 { checksum -= 90000 }
   }
   i += 1
}
def res = __flt_sqrt(float(vbv / vv))
def end = ticks()
print("Result:", res)
print("Time:", (end - start) / 1000000, "ms")
print("checksum=", checksum)
print("elapsed_ns=", end - start)
NY
  source c <<'C'
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

static int64_t now_ns(void) {
    return (int64_t)((double)clock() * 1000000000.0 / (double)CLOCKS_PER_SEC);
}

static double sqrt_approx(double x) {
    if (x <= 0.0) return 0.0;
    double g = x > 1.0 ? x : 1.0;
    for (int i = 0; i < 24; i++) g = 0.5 * (g + x / g);
    return g;
}
static double A(int i, int j) {
    int ij = i + j;
    return 1.0 / (double)(((ij * (ij + 1)) >> 1) + i + 1);
}
static void mul_Av(const double *x, double *out, int n) {
    for (int i = 0; i < n; i++) {
        double sum = 0.0;
        for (int j = 0; j < n; j++) sum += A(i, j) * x[j];
        out[i] = sum;
    }
}
static void mul_Atv(const double *x, double *out, int n) {
    for (int i = 0; i < n; i++) {
        double sum = 0.0;
        for (int j = 0; j < n; j++) sum += A(j, i) * x[j];
        out[i] = sum;
    }
}
int main(void) {
    const int n = 64, iters = 2;
    double *u = (double *)malloc((size_t)n * sizeof(double));
    double *v = (double *)calloc((size_t)n, sizeof(double));
    double *tmp = (double *)calloc((size_t)n, sizeof(double));
    if (!u || !v || !tmp) return 2;
    for (int i = 0; i < n; i++) u[i] = 1.0;
    int64_t start = now_ns();
    for (int i = 0; i < iters; i++) {
        mul_Av(u, tmp, n); mul_Atv(tmp, v, n);
        mul_Av(v, tmp, n); mul_Atv(tmp, u, n);
    }
    double vbv = 0.0, vv = 0.0;
    long long checksum = 0;
    for (int i = 0; i < n; i++) {
        vbv += u[i] * v[i];
        vv += v[i] * v[i];
        if (i < 16) {
            checksum += (long long)(i + 1) * 97;
            if (checksum > 90000) checksum -= 90000;
        }
    }
    double res = sqrt_approx(vbv / vv);
    int64_t end = now_ns();
    free(u); free(v); free(tmp);
    printf("checksum=%lld\n", checksum);
    printf("result=%.12f\n", res);
    if (end <= start) end = start + 1;
    printf("elapsed_ns=%lld\n", (long long)(end - start));
    return 0;
}
C
}
