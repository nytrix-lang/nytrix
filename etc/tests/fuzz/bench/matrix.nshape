shape matrix {
  family "perf-real"
  generator "stress"
  features ["perf", "c-vs-ny", "checksum", "matrix"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time

def n = 36
mut a = list()
mut b = list()
mut c = list()
mut i = 0
while i < n * n {
   a = a.append((i * 3 + 1) - (((i * 3 + 1) / 97) * 97))
   b = b.append((i * 7 + 2) - (((i * 7 + 2) / 89) * 89))
   c = c.append(0)
   i += 1
}

def start = ticks()
mut row = 0
while row < n {
   mut col = 0
   while col < n {
      mut sum = 0
      mut k = 0
      while k < n {
         sum += a.get(row * n + k) * b.get(k * n + col)
         k += 1
      }
      c.set(row * n + col, sum)
      col += 1
   }
   row += 1
}

mut checksum = 0
i = 0
while i < n * n {
   checksum += c.get(i)
   i += 1
}
def end = ticks()
print("checksum=", checksum)
print("elapsed_ns=", end - start)
NY
  source c <<'C'
#include <stdint.h>
#include <stdio.h>
#include <time.h>

#define N 36

static int64_t now_ns(void) {
    return (int64_t)((double)clock() * 1000000000.0 / (double)CLOCKS_PER_SEC);
}

int main(void) {
    int64_t a[N * N];
    int64_t b[N * N];
    int64_t c[N * N];
    for (int i = 0; i < N * N; i++) {
        a[i] = (i * 3 + 1) % 97;
        b[i] = (i * 7 + 2) % 89;
        c[i] = 0;
    }
    int64_t start = now_ns();
    for (int row = 0; row < N; row++) {
        for (int col = 0; col < N; col++) {
            int64_t sum = 0;
            for (int k = 0; k < N; k++) {
                sum += a[row * N + k] * b[k * N + col];
            }
            c[row * N + col] = sum;
        }
    }
    int64_t checksum = 0;
    for (int i = 0; i < N * N; i++) checksum += c[i];
    int64_t end = now_ns();
    printf("checksum=%lld\n", (long long)checksum);
    if (end <= start) end = start + 1;
    printf("elapsed_ns=%lld\n", (long long)(end - start));
    return 0;
}
C
  source py <<'PY'
import time

N = 36
a = [((i * 3 + 1) % 97) for i in range(N * N)]
b = [((i * 7 + 2) % 89) for i in range(N * N)]
c = [0 for _ in range(N * N)]

start = time.process_time_ns()
for row in range(N):
    for col in range(N):
        s = 0
        for k in range(N):
            s += a[row * N + k] * b[k * N + col]
        c[row * N + col] = s
end = time.process_time_ns()

print(f"checksum={sum(c)}")
print(f"elapsed_ns={max(1, end - start)}")
PY
}
