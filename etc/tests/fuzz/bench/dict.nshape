shape dict {
  family "perf-real"
  generator "stress"
  features ["perf", "c-vs-ny", "checksum"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time
;; Dict (Benchmark)
mut d = dict()
def t_start = ticks()
mut i = 0
while i < 1000 {
   d = d.set(to_str(i), i)
   i = i + 1
}
def t_mid = ticks()
print("Insert(100k items) took(ns): ", t_mid - t_start)
mut idx = 0
while idx < 1000 {
   d.get(to_str(idx), -1)
   idx = idx + 1
}
def t_end = ticks()
print("Lookup(100k items) took(ns): ", t_end - t_mid)
print("Time(ns): ", t_end - t_start)
NY
  source c <<'C'
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

static int64_t now_ns(void) {
    return (int64_t)((double)clock() * 1000000000.0 / (double)CLOCKS_PER_SEC);
}

typedef struct { char key[16]; int value; int used; } Entry;
#define CAP 2048
static uint32_t hash_key(const char *s) {
    uint32_t h = 2166136261u;
    while (*s) { h ^= (unsigned char)*s++; h *= 16777619u; }
    return h;
}
static void dict_set(Entry *tab, const char *key, int value) {
    uint32_t i = hash_key(key) & (CAP - 1);
    while (tab[i].used && strcmp(tab[i].key, key) != 0) i = (i + 1) & (CAP - 1);
    tab[i].used = 1;
    snprintf(tab[i].key, sizeof(tab[i].key), "%s", key);
    tab[i].value = value;
}
static int dict_get(Entry *tab, const char *key, int fallback) {
    uint32_t i = hash_key(key) & (CAP - 1);
    for (int probes = 0; probes < CAP; probes++) {
        if (!tab[i].used) return fallback;
        if (strcmp(tab[i].key, key) == 0) return tab[i].value;
        i = (i + 1) & (CAP - 1);
    }
    return fallback;
}
int main(void) {
    Entry *tab = (Entry *)calloc(CAP, sizeof(Entry));
    if (!tab) return 2;
    char key[16];
    int64_t checksum = 0;
    int64_t start = now_ns();
    for (int i = 0; i < 1000; i++) { snprintf(key, sizeof(key), "%d", i); dict_set(tab, key, i); }
    for (int i = 0; i < 1000; i++) { snprintf(key, sizeof(key), "%d", i); checksum += dict_get(tab, key, -1); }
    int64_t end = now_ns();
    free(tab);
    printf("checksum=%lld\n", (long long)checksum);
    if (end <= start) end = start + 1;
    printf("elapsed_ns=%lld\n", (long long)(end - start));
    return 0;
}
C
}
