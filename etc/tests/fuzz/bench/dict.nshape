shape dict {
  family "perf-real"
  generator "stress"
  features ["perf", "c-vs-ny", "checksum"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time
;; Dict (Benchmark)
mut d = dict()
def t_start = ticks()
mut i = 0
while i < 1000 {
   d = d.set(i, i)
   i += 1
}
def t_mid = ticks()
print("Insert(1k items) took(ns): ", t_mid - t_start)
mut idx = 0
mut checksum = 0
while idx < 1000 {
   checksum += d.get(idx, -1)
   idx += 1
}
def t_end = ticks()
print("Lookup(1k items) took(ns): ", t_end - t_mid)
print("Time(ns): ", t_end - t_start)
print("checksum=", checksum)
print("elapsed_ns=", t_end - t_start)
NY
  source c <<'C'
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

static int64_t now_ns(void) {
    return (int64_t)((double)clock() * 1000000000.0 / (double)CLOCKS_PER_SEC);
}

typedef struct { int key; int value; int used; } Entry;
#define CAP 2048
static uint32_t hash_key(int key) {
    uint32_t x = (uint32_t)key;
    x ^= x >> 16;
    x *= 0x7feb352du;
    x ^= x >> 15;
    x *= 0x846ca68bu;
    x ^= x >> 16;
    return x;
}
static void dict_set(Entry *tab, int key, int value) {
    uint32_t i = hash_key(key) & (CAP - 1);
    while (tab[i].used && tab[i].key != key) i = (i + 1) & (CAP - 1);
    tab[i].used = 1;
    tab[i].key = key;
    tab[i].value = value;
}
static int dict_get(Entry *tab, int key, int fallback) {
    uint32_t i = hash_key(key) & (CAP - 1);
    for (int probes = 0; probes < CAP; probes++) {
        if (!tab[i].used) return fallback;
        if (tab[i].key == key) return tab[i].value;
        i = (i + 1) & (CAP - 1);
    }
    return fallback;
}
int main(void) {
    Entry *tab = (Entry *)calloc(CAP, sizeof(Entry));
    if (!tab) return 2;
    int64_t checksum = 0;
    int64_t start = now_ns();
    for (int i = 0; i < 1000; i++) { dict_set(tab, i, i); }
    for (int i = 0; i < 1000; i++) { checksum += dict_get(tab, i, -1); }
    int64_t end = now_ns();
    free(tab);
    printf("checksum=%lld\n", (long long)checksum);
    if (end <= start) end = start + 1;
    printf("elapsed_ns=%lld\n", (long long)(end - start));
    return 0;
}
C
  source py <<'PY'
import time

start = time.process_time_ns()
d = {}
for i in range(1000):
    d[i] = i
checksum = 0
for i in range(1000):
    checksum += d.get(i, -1)
end = time.process_time_ns()
print(f"checksum={checksum}")
print(f"elapsed_ns={max(1, end - start)}")
PY
}
