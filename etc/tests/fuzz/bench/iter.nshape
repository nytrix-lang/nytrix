shape iter {
  family "perf-real"
  generator "stress"
  features ["perf", "c-vs-ny", "checksum"]
  template ny-test-case
  expect compile_and_run
  source ny <<'NY'
use std.core
use std.os.time
def n = 20000
def xs = malloc(n * 8)
def mapped = malloc(n * 8)
def reversed = malloc(n * 8)
def chained = malloc(n * 16)
mut i = 0
while i < n {
   store64(xs, i, i * 8)
   i += 1
}
def start = ticks()
i = 0
while i < n {
   def v = load64(xs, i * 8) + 1
   store64(mapped, v, i * 8)
   store64(chained, v, i * 8)
   i += 1
}
i = 0
while i < n {
   def v = load64(mapped, (n - 1 - i) * 8)
   store64(reversed, v, i * 8)
   store64(chained, v, (n + i) * 8)
   i += 1
}
mut sum = 0
i = 0
while i < n * 2 {
   sum += load64(chained, i * 8)
   i += 1
}
def end = ticks()
free(xs)
free(mapped)
free(reversed)
free(chained)
print("Iter benchmark passed, sum =", sum)
print("Time(ns): ", end - start)
print("checksum=", sum)
print("elapsed_ns=", end - start)
NY
  source c <<'C'
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

static int64_t now_ns(void) {
    return (int64_t)((double)clock() * 1000000000.0 / (double)CLOCKS_PER_SEC);
}

int main(void) {
    const int n = 20000;
    int *xs = (int *)malloc((size_t)n * sizeof(int));
    int *mapped = (int *)malloc((size_t)n * sizeof(int));
    int *reversed = (int *)malloc((size_t)n * sizeof(int));
    int *chained = (int *)malloc((size_t)n * 2 * sizeof(int));
    if (!xs || !mapped || !reversed || !chained) return 2;
    for (int i = 0; i < n; i++) xs[i] = i;
    int64_t start = now_ns();
    for (int i = 0; i < n; i++) mapped[i] = xs[i] + 1;
    for (int i = 0; i < n; i++) reversed[i] = mapped[n - 1 - i];
    memcpy(chained, mapped, (size_t)n * sizeof(int));
    memcpy(chained + n, reversed, (size_t)n * sizeof(int));
    int64_t sum = 0;
    for (int i = 0; i < n * 2; i++) sum += chained[i];
    int64_t end = now_ns();
    free(xs); free(mapped); free(reversed); free(chained);
    printf("checksum=%lld\n", (long long)sum);
    if (end <= start) end = start + 1;
    printf("elapsed_ns=%lld\n", (long long)(end - start));
    return 0;
}
C
}
