shape heap-raii-gc-conflict {
  family "compiler-errors/heap"
  generator "error"
  features ["error", "heap", "negative", "diagnostic"]
  template ny-compile-fail
  expect compile_fail

  expect_message "--heap=raii cannot be combined with -gc"
  flags "--heap=raii -gc"
  source ny <<'NY'
print(1)
NY
}
